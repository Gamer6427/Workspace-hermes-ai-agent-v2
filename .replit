modules = ["nodejs-20", "web", "python-3.12", "bash"]
[agent]
expertMode = true
stack = "GAMESTACK_JS"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "5000"
MODEL_API_TOKEN = "Fh2uj3K9j6XdoUi4H2WyvEAVa7qzUZXL"

[workflows]
runButton = "Project"

[[workflows.workflow]]
